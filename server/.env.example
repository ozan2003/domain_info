# Server environment variables
# Copy this file to `.env` and fill in real values.

# SQLite database file (relative to the server working directory)
DATABASE_URL=file:./dev.db

# JWT signing key. MUST be >= 32 characters and MUST NOT contain "change-me".
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-48-bytes-of-random-hex

# Set to "production" on the EC2 instance. This makes the auth cookie Secure
# (HTTPS-only) and disables verbose error messages.
NODE_ENV=production

# Backend listen port. Leave as 6633 — nginx proxies /api to this port.
PORT=6633
